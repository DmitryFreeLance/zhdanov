APP_MODE=run
APP_ZONE_ID=Asia/Novosibirsk
APP_DATABASE_PATH=./data/wb-max-bot.db
APP_MAX_DOMAIN=bot.example.com
APP_HOST_PORT=18080

APP_SCHEDULER_ENABLED=true
APP_SCHEDULER_FIXED_DELAY=PT10M
APP_SCHEDULER_INITIAL_DELAY=PT1M

APP_WILDBERRIES_REPORT_URL=https://logistics.wildberries.ru/reports/remainders/last-mile/chart
APP_WILDBERRIES_HEADLESS=true
APP_WILDBERRIES_TIMEOUT=PT45S
APP_WILDBERRIES_BOOTSTRAP_TIMEOUT=PT30M
APP_WILDBERRIES_STORAGE_STATE_PATH=./data/wb-storage-state.json

APP_MAX_ENABLED=true
APP_MAX_TOKEN=replace_with_max_bot_token
APP_MAX_LONG_POLLING_ENABLED=true
APP_MAX_LONG_POLLING_TIMEOUT=PT30S
APP_MAX_LONG_POLLING_LIMIT=100
APP_MAX_PUBLIC_WEBHOOK_URL=https://bot.example.com/webhook/max
APP_MAX_WEBHOOK_SECRET=replace_with_secret
APP_MAX_AUTO_REGISTER_WEBHOOK=false

APP_ALERT_SHK_THRESHOLD=1200
APP_ALERT_RATIO_THRESHOLD=0.9
APP_ALERT_COOLDOWN=PT30M
APP_ALERT_SEND_REPORT_EACH_RUN=true
APP_ALERT_MAX_ROWS_IN_MESSAGE=50
APP_ALERT_VOICE_CALL_ENABLED=false

APP_TELEPHONY_PROVIDER=noop
APP_TELEPHONY_TARGET_NUMBERS=

APP_TELEPHONY_MANGO_API_KEY=replace_with_api_key
APP_TELEPHONY_MANGO_API_SALT=replace_with_api_salt
APP_TELEPHONY_MANGO_EXTENSION=101
APP_TELEPHONY_MANGO_FROM_NUMBER=sip:employee@example.mangosip.ru
APP_TELEPHONY_MANGO_LINE_NUMBER=

APP_TELEPHONY_TWILIO_ACCOUNT_SID=replace_with_sid
APP_TELEPHONY_TWILIO_AUTH_TOKEN=replace_with_auth_token
APP_TELEPHONY_TWILIO_FROM_NUMBER=+10000000000
APP_TELEPHONY_TWILIO_LANGUAGE=ru-RU
APP_TELEPHONY_TWILIO_VOICE=alice

APP_TELEPHONY_ZADARMA_KEY=replace_with_key
APP_TELEPHONY_ZADARMA_SECRET=replace_with_secret
APP_TELEPHONY_ZADARMA_FROM=100
APP_TELEPHONY_ZADARMA_SIP=100
APP_TELEPHONY_ZADARMA_PREDICTED=true

APP_ADMIN_TOKEN=replace_with_admin_token
